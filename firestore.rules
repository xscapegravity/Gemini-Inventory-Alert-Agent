rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "martyn.frank@gmail.com"
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'uid']) &&
             data.email is string &&
             data.role in ['admin', 'standard'] &&
             data.uid is string &&
             (!('password' in data) || data.password is string);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      // Allow users to read their own data, and admins to read all user data
      allow read: if isOwner(uid) || isAdmin();
      
      // Allow users to create their own profile if authenticated
      // Allow users to update their own profile, and admins to update any profile
      // Ensure data validation on write
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data);
      
      // Allow only admins to delete users
      allow delete: if isAdmin();
    }

    match /inventoryHistory/{historyId} {
      // Users can read their own history, admins can read all
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      
      // Users can create their own history records
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Only admins can modify or delete history
      allow update, delete: if isAdmin();
    }
  }
}
